# Dumps crudos de SEPA (pesados; no se versionan). Solo se versiona data/ips.json procesado.
*.zip
sepa/
scripts/__pycache__/
.DS_Store
data/buscador.json
# Datos de la yerba: viven en la rama `yerba-datos` (acumula histórico), no en main.
data/yerba/
